<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>net8.0</TargetFramework>
		<DevelopmentDependency>true</DevelopmentDependency>

		<Version>1.0.0</Version>
	</PropertyGroup>

	<!-- Nuget Properties -->
	<PropertyGroup>
		<IsPackable>true</IsPackable>
		<PackageType>MSBuildSdk</PackageType>

		<PackageId>WarperSan.ThunderPipe.Sdk</PackageId>
		<Authors>WarperSan</Authors>
		<Description>MSBuild integration for ThunderPipe</Description>
	</PropertyGroup>

	<!-- Content includes -->
	<ItemGroup>
		<Content Include="Sdk/*" Pack="true" PackagePath="Sdk/" />
		<Content
			Include="$(ProjectDir)../ThunderPipe.MSBuild/bin/$(Configuration)/$(TargetFramework)/**/*"
			Pack="true"
			PackagePath="build/$(TargetFramework)/"
			Visible="false"
		/>
	</ItemGroup>
</Project>
