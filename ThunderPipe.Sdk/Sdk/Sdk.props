	<PropertyGroup>
		<ThunderPipeOutputDir>$(MSBuildProjectDirectory)/artifacts/thunderstore/</ThunderPipeOutputDir>
		<ThunderPipeToken></ThunderPipeToken>

		<ThunderstoreHost></ThunderstoreHost>
		<ThunderPipeLogLevel></ThunderPipeLogLevel>

		<ThunderstoreCommunity></ThunderstoreCommunity>
	</PropertyGroup>
</Project>
