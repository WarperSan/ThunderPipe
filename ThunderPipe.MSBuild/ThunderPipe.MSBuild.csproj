<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>net8.0</TargetFramework>
		<DevelopmentDependency>true</DevelopmentDependency>

		<PackageId>WarperSan.ThunderPipe.MSBuild</PackageId>
		<Description>MSBuild integration for ThunderPipe</Description>
		<Version>1.0.0</Version>

		<PackageType>MSBuildSdk</PackageType>
		<IsPackable>true</IsPackable>
		<NoPackageAnalysis>true</NoPackageAnalysis>
	</PropertyGroup>

	<!-- Content includes -->
	<ItemGroup>
		<Content Include="Sdk/*" Pack="true" PackagePath="Sdk/" />
		<Content
			Include="$(ProjectDir)../ThunderPipe.MSBuild.Tasks/bin/$(Configuration)/$(TargetFramework)/**/*"
			Pack="true"
			PackagePath="build/$(TargetFramework)/"
			Visible="false"
		/>
	</ItemGroup>
</Project>
